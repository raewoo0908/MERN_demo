{
  "name": "ddareungi-scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ingest:stations": "tsx src/ingestStations.ts",
    "ingest:hourly": "tsx src/ingestHourlyUsage.ts",
    "ingest:monthly": "tsx src/ingestStationMonthly.ts",
    "ingest:weather": "tsx src/ingestWeather.ts",
    "agg:hourly": "tsx src/aggregate/aggHourly.ts",
    "agg:stationDowHour": "tsx src/aggregate/aggStationDowHour.ts",
    "agg:dowHourUsertype": "tsx src/aggregate/aggDowHourUsertype.ts",
    "agg:demographicHour": "tsx src/aggregate/aggDemographicHour.ts",
    "agg:stationTotal": "tsx src/aggregate/aggStationTotal.ts",
    "agg:monthlyTrend": "tsx src/aggregate/aggMonthlyTrend.ts",
    "agg:all": "npm run agg:hourly && npm run agg:stationDowHour && npm run agg:dowHourUsertype && npm run agg:demographicHour && npm run agg:stationTotal && npm run agg:monthlyTrend",
    "stream:raw": "tsx src/aggregate/streamRawTrips.ts",
    "upload:atlas": "tsx src/uploadToAtlas.ts"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "iconv-lite": "^0.6.3",
    "mongoose": "^8.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
