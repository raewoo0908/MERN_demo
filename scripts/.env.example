# Local MongoDB (via docker compose) — destination for raw ingestion
MONGO_URI_LOCAL=mongodb://localhost:27017/ddareungi

# MongoDB Atlas — destination for aggregated collections (used in Day 3)
MONGO_URI_ATLAS=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ddareungi

# Seoul Open Data Plaza API key — http://data.seoul.go.kr
SEOUL_OPEN_API_KEY=

# Korea Meteorological Administration (KMA) API key — https://apihub.kma.go.kr
KMA_API_KEY=

# Ingestion time window (KST). Inclusive date range.
# Used by ingestWeather.ts and other time-bounded scripts.
ANALYSIS_START_DATE=2025-11-01
ANALYSIS_END_DATE=2025-12-31
