# ─── Local dev ────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed origins. *.vercel.app preview URLs are
# additionally allowed via regex in src/index.ts (no config needed for them).
CLIENT_URL=http://localhost:5173

# Local MongoDB (via `docker compose up -d`).
MONGO_URI=mongodb://localhost:27017/ddareungi

# ─── Production (Render) ──────────────────────────────────────
# Do NOT put prod values in this file. Set them in the Render dashboard:
#   Environment tab → Add Environment Variable
#
#   MONGO_URI   mongodb+srv://<reader>:<pw>@<cluster>.mongodb.net/test?retryWrites=true&w=majority
#   CLIENT_URL  https://<your-project>.vercel.app
#   NODE_ENV    production
#
# Render auto-injects PORT (10000). Our code reads process.env.PORT ?? 4000.
